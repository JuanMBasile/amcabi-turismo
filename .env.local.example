# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# 1. Creá una cuenta en https://sanity.io
# 2. Creá un nuevo proyecto (gratis)
# 3. Copiá el Project ID y el Dataset name aquí

NEXT_PUBLIC_SANITY_PROJECT_ID=tu-project-id-aqui
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Webhook de revalidación (para actualizaciones instantáneas) ──────────────
# Generá una clave secreta aleatoria (ej: openssl rand -hex 32)
# Configurá esta misma clave en Sanity → API → Webhooks → Secret
SANITY_REVALIDATE_SECRET=tu-clave-secreta-aqui
